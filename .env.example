# ----------------------------------------------------------
# The Soundtrack of Bert — environment variables
# Copy this file to `.env` and fill in the values you need.
# ----------------------------------------------------------

# ── Genre enrichment (recommended) ─────────────────────────
# If set, `npm run ingest` will enrich the top ~600 artists with real
# genres via the Spotify Web API (Client Credentials flow). Without
# these, every artist falls back to genre = "Unknown" and the
# streamgraph collapses to a single band.
#
# How to get them (2 minutes, free):
#   1. Go to https://developer.spotify.com/dashboard
#   2. Click "Create app", pick any name/description, set redirect to
#      http://localhost (we don't use it — Client Credentials flow only).
#   3. Open the app → Settings → copy Client ID and Client secret.
#   4. Paste below, then run:  npm run ingest
#
# No user login or OAuth scopes needed. App-level token is enough.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Hosting ───────────────────────────────────────────────
# Public base path the app is served from. Must match the Vite `base`
# setting and your nginx location block. For root hosting use "/", for
# the planned subdirectory deploy use "/spotify26/".
VITE_BASE_PATH=/spotify26/
