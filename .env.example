# ----------------------------------------------------------
# The Soundtrack of Bert — environment variables
# Copy this file to `.env` and fill in the values you need.
# ----------------------------------------------------------

# Optional. If set, `npm run ingest` will enrich artists with real Spotify
# genre data via the public Web API (Client Credentials flow).
# Get them at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Public base path the app is served from. Must match the Vite `base` setting
# and your nginx location block. For root hosting use "/", for the planned
# subdirectory deploy use "/spotify26/".
VITE_BASE_PATH=/spotify26/
