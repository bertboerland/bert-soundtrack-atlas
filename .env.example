# ----------------------------------------------------------
# The Soundtrack of Bert — environment variables
# Copy this file to `.env` and fill in the values you need.
# ----------------------------------------------------------

# ── Genre enrichment via Last.fm (recommended) ─────────────
# Spotify removed the `genres` field from its public search API for new apps
# (Nov 2024), so we use Last.fm's free API instead. It is fast (no hard rate
# limit for read endpoints) and returns top user-tags per artist, which we
# treat as the genre.
#
# How to get a key (2 minutes, free, no approval needed):
#   1. Go to https://www.last.fm/api/account/create
#   2. Sign in (or create a free Last.fm account).
#   3. Fill in:
#        Application name : soundtrack-of-bert
#        Application desc : Personal listening-history visualisation
#        Callback URL     : (leave blank)
#        Homepage         : (leave blank or your domain)
#   4. Submit → copy the "API key" value (the "Shared secret" is NOT needed
#      for our read-only artist.getInfo calls).
#   5. Paste below, then run:  npm run ingest
LASTFM_API_KEY=

# ── Spotify (optional, currently unused for genres) ────────
# Kept for future features (audio features, album art). Genre enrichment no
# longer works via Spotify for apps created after 2024-11-27.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Hosting ───────────────────────────────────────────────
VITE_BASE_PATH=/spotify26/
